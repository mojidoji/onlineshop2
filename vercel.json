{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 60,
      "regions": [
        "iad1"
      ]
    }
  },
  "rewrites": [
    { "source": "/site", "destination": "/site/wellcome" },
    { "source": "/site/:path*", "destination": "/site/wellcome" },
    { "source": "/:path*", "destination": "/site/wellcome" }
  ],
  "trailingSlash": false
}
